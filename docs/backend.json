{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Akun operator sistem dengan akses berbasis peran.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "email", "role"]
    },
    "Station": {
      "title": "Station",
      "type": "object",
      "description": "Representasi unit hardware (TV/Console) yang dikontrol via ADB.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["PS3", "PS4", "PS5"] },
        "ipAddress": { "type": "string" },
        "stationIndex": { "type": "number" },
        "status": { "type": "string", "enum": ["connected", "disconnected"] },
        "is_active": { "type": "boolean" },
        "is_paused": { "type": "boolean" },
        "start_time": { "type": "number" },
        "end_time": { "type": "number" },
        "remaining_seconds": { "type": "number" },
        "current_transaction_id": { "type": "string" },
        "last_action": { "type": "string" },
        "last_action_timestamp": { "type": "number" }
      }
    },
    "PricingRule": {
      "title": "PricingRule",
      "type": "object",
      "description": "Daftar harga paket sewa PS atau Kupon Wi-Fi.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "duration": { "type": "number" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["PS3", "PS4", "PS5", "All", "Wifi"] }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Log keuangan untuk setiap sesi bermain, penjualan kantin, atau kupon wifi.",
      "properties": {
        "id": { "type": "string" },
        "stationId": { "type": "string" },
        "stationName": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "amount": { "type": "number" },
        "discount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "shiftId": { "type": "string" },
        "claimCode": { "type": "string" }
      }
    },
    "Member": {
        "title": "Member",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "points": { "type": "number" },
            "stamps": { "type": "number" },
            "joinDate": { "type": "number" },
            "lastActivity": { "type": "number" }
        }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "Profil pengguna sistem." },
    "/stations/{stationId}": { "schema": { "$ref": "#/backend/entities/Station" }, "description": "Status unit hardware." },
    "/transactions/{transactionId}": { "schema": { "$ref": "#/backend/entities/Transaction" }, "description": "Log keuangan." },
    "/pricingRules/{ruleId}": { "schema": { "$ref": "#/backend/entities/PricingRule" }, "description": "Daftar harga paket sewa & wifi." },
    "/members/{memberId}": { "schema": { "$ref": "#/backend/entities/Member" }, "description": "Data loyalitas pelanggan." }
  }
}